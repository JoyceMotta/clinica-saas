generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?
}

model Cliente {
  id String @id @default(cuid())

  // ── Dados pessoais ──────────────────────────────────────
  nome           String
  cpf            String   @unique
  rg             String?
  rgOrgaoEmissor String?
  dataNascimento DateTime
  sexo           String?
  estadoCivil    String?
  profissao      String?
  nacionalidade  String?

  // ── Contato ────��────────────────────────────────────────
  whatsapp    String
  telefoneFix String?
  email       String?

  // ── Endereço ───────��────────────────────────────────────
  cep         String?
  rua         String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?

  // ── Contato de emergência ───────���────────────────────────
  nomeEmergencia       String?
  parentescoEmergencia String?
  telefoneEmergencia   String?

  // ── Menor de idade ���──────────────────────────────────────
  menorDeIdade Boolean @default(false)

  // ── Responsável legal ────────────────────────────────────
  nomeResponsavel          String?
  cpfResponsavel           String?
  rgResponsavel            String?
  dataNascResponsavel      DateTime?
  parentescoResponsavel    String?
  whatsappResponsavel      String?
  emailResponsavel         String?
  enderecoResponsavelIgual Boolean   @default(true)
  cepResponsavel           String?
  ruaResponsavel           String?
  numeroResponsavel        String?
  complementoResponsavel   String?
  bairroResponsavel        String?
  cidadeResponsavel        String?
  ufResponsavel            String?

  // ── Como nos conheceu ────────────────────────────────────
  comoConheceu String?

  // ── Aniversário ───────────────────────────────────────────
  aniversarioMensagem Boolean @default(true)
  mensagemAniversario String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clientes")
}
